{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tabib (web-server)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "deviceId": "web-server",
            "args": [
                "--web-port=8080",
                "--web-hostname=127.0.0.1"
            ],
            "toolArgs": [
                "--dart-define=use_arabic=true",
                "--dart-define=use_bidi=false"
            ],
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "is being served at (https?://\\S+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Tabib (Chrome)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "deviceId": "chrome",
            "args": [
                "--web-port=8080",
                "--web-hostname=127.0.0.1"
            ],
            "toolArgs": [
                "--dart-define=use_arabic=true",
                "--dart-define=use_bidi=false"
            ]
        }
    ]
}
