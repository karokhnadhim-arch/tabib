rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function isSystemOwner() {
      return signedIn() && userData().isSystemOwner == true;
    }

    function isDoctor() {
      return signedIn() && userData().role == 'doctor';
    }

    function accountActive() {
      return userData().isActive != false;
    }

    function staffDoctorId() {
      return userData().doctorId;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/jpeg')
        && request.resource.size < 2 * 1024 * 1024;
    }

    match /tabib/images/doctors/profile/{doctorId}/{fileName} {
      allow read: if true;
      allow write: if isImageUpload() && (
        isSystemOwner()
        || (isDoctor() && accountActive() && staffDoctorId() == doctorId)
      );
    }

    match /tabib/images/clinics/photos/{doctorId}/{fileName} {
      allow read: if true;
      allow write: if isImageUpload() && (
        isSystemOwner()
        || (isDoctor() && accountActive() && staffDoctorId() == doctorId)
      );
    }

    match /tabib/images/general/{ownerId}/{fileName} {
      allow read: if true;
      allow write: if isImageUpload() && signedIn();
    }
  }
}
