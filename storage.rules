rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/jpeg')
        && request.resource.size < 2 * 1024 * 1024;
    }

    // Doctor profile photos — doctors upload to their own folder.
    match /images/doctors/{doctorId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUpload();
    }

    // Clinic gallery — authenticated staff can upload optimized JPEGs.
    match /images/clinics/{clinicId}/gallery/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUpload();
    }

    // Reserved for future staff profile uploads.
    match /images/staff/{staffId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUpload();
    }

    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
